{
  "name": "capela-fatima-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "API da Capela Nossa Senhora de Fátima — Hono no Cloudflare Workers (D1 + Backblaze B2)",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply capela-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply capela-db --remote"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.95.0"
  }
}
